{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/shoot-plan.schema.json",
  "title": "Photography Shoot Plan",
  "type": "object",
  "required": ["title", "date", "locations", "astronomySummary", "weatherSummary", "cameraSummary", "itinerary"],
  "properties": {
    "title": { "type": "string" },
    "date": { "type": "string" },
    "locations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/location" } },
    "astronomySummary": { "type": "string" },
    "weatherSummary": { "type": "string" },
    "cameraSummary": { "type": "string" },
    "itinerary": { "type": "array", "items": { "type": "string" } },
    "packing": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "location": {
      "type": "object",
      "required": ["name", "coordinates", "bestWindow", "notes"],
      "properties": {
        "name": { "type": "string" },
        "coordinates": { "type": "object", "required": ["latitude", "longitude"], "properties": { "latitude": { "type": "number", "minimum": -90, "maximum": 90 }, "longitude": { "type": "number", "minimum": -180, "maximum": 180 } } },
        "bestWindow": { "type": "string" },
        "direction": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
